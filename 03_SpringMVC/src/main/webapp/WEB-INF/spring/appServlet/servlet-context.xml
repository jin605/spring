<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:p="http://www.springframework.org/schema/p"
       xmlns:mvc="http://www.springframework.org/schema/mvc"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd http://www.springframework.org/schema/mvc https://www.springframework.org/schema/mvc/spring-mvc.xsd http://www.springframework.org/schema/context https://www.springframework.org/schema/context/spring-context.xsd">
    <!--
        어노테이션 기반의 Spring MVC 기능을 활성화한다.
        @RequestMapping,@GetMapping, @PostMapping 등의 어노테이션을 사용할 수 있도록 해준다.
    -->
    <mvc:annotation-driven/>

    <!--
        정적 자원(이미지, css, js등)을 제공하기 위한 매핑을 설정한다.

        클라이언트부터 https://localhost:8080/mvc/resources/images/pikachu.jpeg 요청이 오면
        해당 요청을 /resources/images/pikachu.jpeg로 매핑시킨다.

    <mvc:resources mapping="/resources/**" location="/resources/"/>
    -->

    <mvc:resources mapping="/images/**" location="/resources/images/"/>
    <mvc:resources mapping="/css/**" location="/resources/css/"/>
    <mvc:resources mapping="/js/**" location="/resources/js/"/>

    <!--
        JSP 파일을 뷰로 사용할 때 결로를 자동으로 구성해 주는 역할을 한다.
        ViewResolve가 "prefix + 뷰이름 + suffix" 형식으로 JSP 파일을 찾는다.
    -->
    <bean class="org.springframework.web.servlet.view.InternalResourceViewResolver"
        p:prefix="/WEB-INF/views/" p:suffix=".jsp"/>
    <!--
        지정된 패키지 하위에 있는 컴포넌트(@Controller, @Service, @Repository 등)을
        자동으로 검색하고 빈으로 등록하는 역할을 한다.
    -->
    <context:component-scan base-package="com.beyond.mvc"/>
</beans>